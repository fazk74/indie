public class HUDManager : MonoBehaviour
{
    [Header("UI Elements")]
    [SerializeField] private Slider staminaBar;
    [SerializeField] private Slider batteryBar;
    [SerializeField] private Text dollsCollectedText;
    [SerializeField] private Image lowBatteryWarning;

    private PlayerController playerController;
    private FlashlightSystem flashlightSystem;
    private BurnDollSystem burnDollSystem;

    private void Start()
    {
        playerController = FindObjectOfType<PlayerController>();
        flashlightSystem = FindObjectOfType<FlashlightSystem>();
        burnDollSystem = FindObjectOfType<BurnDollSystem>();
    }

    private void Update()
    {
        UpdateStaminaBar();
        UpdateBatteryBar();
        UpdateDollCounter();
    }

    private void UpdateStaminaBar()
    {
        if (playerController)
        {
            staminaBar.value = playerController.CurrentStamina / playerController.MaxStamina;
        }
    }

    private void UpdateBatteryBar()
    {
        if (flashlightSystem)
        {
            batteryBar.value = flashlightSystem.CurrentBattery / flashlightSystem.MaxBattery;
            lowBatteryWarning.enabled = flashlightSystem.IsBatteryLow;
        }
    }

    private void UpdateDollCounter()
    {
        if (burnDollSystem)
        {
            dollsCollectedText.text = "Dolls: " + burnDollSystem.DollsBurned + "/" + burnDollSystem.TotalDolls;
        }
    }
}
