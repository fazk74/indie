public class HaairaAI : MonoBehaviour
{
    public enum AIState { Passive, Hunting, Transformed, Defeated }

    [Header("AI Behavior")]
    [SerializeField] private float visionRange = 30f;
    [SerializeField] private float hearingRange = 20f;
    [SerializeField] private float chaseSpeed = 6f;
    [SerializeField] private float patrolSpeed = 2f;
    [SerializeField] private float attackDistance = 2f;

    [Header("Patrol Points")]
    [SerializeField] private Transform[] patrolPoints;

    [Header("Transformation")]
    [SerializeField] private int transformationThreshold = 6; // After 6 dolls burned

    [Header("Audio")]
    [SerializeField] private AudioClip laughSound;
    [SerializeField] private AudioClip painScreamSound;
    [SerializeField] private AudioClip monsterGrowlSound;

    private NavMeshAgent navMeshAgent;
    private Transform playerTransform;
    private AudioSource audioSource;
    private AIState currentState = AIState.Passive;
    private int patrolIndex = 0;
    private bool isTransformed = false;
    private Animator animator;
    private float laughTimer;

    public AIState CurrentState => currentState;
    public bool IsTransformed => isTransformed;

    private void Start()
    {
        navMeshAgent = GetComponent<NavMeshAgent>();
        audioSource = GetComponent<AudioSource>();
        animator = GetComponent<Animator>();
        playerTransform = GameObject.FindGameObjectWithTag("Player").transform;
        navMeshAgent.speed = patrolSpeed;
    }

    private void Update()
    {
        switch (currentState)
        {
            case AIState.Passive:
                PatrolBehavior();
                CheckForPlayer();
                break;
            case AIState.Hunting:
                HuntPlayer();
                break;
            case AIState.Transformed:
                HuntPlayerTransformed();
                break;
            case AIState.Defeated:
                navMeshAgent.velocity = Vector3.zero;
                break;
        }

        HandleLaughing();
    }

    private void PatrolBehavior()
    {
        if (patrolPoints.Length == 0) return;

        if (!navMeshAgent.hasPath || navMeshAgent.remainingDistance < 0.5f)
        {
            patrolIndex = (patrolIndex + 1) % patrolPoints.Length;
            navMeshAgent.SetDestination(patrolPoints[patrolIndex].position);
        }
    }

    private void CheckForPlayer()
    {
        float distanceToPlayer = Vector3.Distance(transform.position, playerTransform.position);

        if (distanceToPlayer < visionRange)
        {
            // Check line of sight
            if (CanSeePlayer())
            {
                currentState = AIState.Hunting;
            }
        }
        else if (distanceToPlayer < hearingRange)
        {
            // Heard player
            currentState = AIState.Hunting;
        }
    }

    private bool CanSeePlayer()
    {
        Vector3 directionToPlayer = (playerTransform.position - transform.position).normalized;
        RaycastHit hit;

        if (Physics.Raycast(transform.position + Vector3.up, directionToPlayer, out hit, visionRange))
        {
            return hit.transform == playerTransform;
        }
        return false;
    }

    private void HuntPlayer()
    {
        navMeshAgent.speed = chaseSpeed;
        navMeshAgent.SetDestination(playerTransform.position);
        animator.SetBool("isHunting", true);

        if (Vector3.Distance(transform.position, playerTransform.position) < attackDistance)
        {
            CatchPlayer();
        }
    }

    private void HuntPlayerTransformed()
    {
        navMeshAgent.speed = chaseSpeed * 1.3f; // Faster when transformed
        navMeshAgent.SetDestination(playerTransform.position);
        animator.SetBool("isHunting", true);

        if (Vector3.Distance(transform.position, playerTransform.position) < attackDistance * 1.5f)
        {
            CatchPlayer();
        }
    }

    private void CatchPlayer()
    {
        // Trigger death/restart
        GameManager.instance.PlayerCaught();
    }

    private void HandleLaughing()
    {
        laughTimer -= Time.deltaTime;
        if (laughTimer <= 0 && currentState == AIState.Passive)
        {
            laughTimer = Random.Range(15f, 30f);
            PlayDistantLaugh();
        }
    }

    private void PlayDistantLaugh()
    {
        audioSource.PlayOneShot(laughSound, 0.4f);
    }

    public void OnDollBurned()
    {
        audioSource.PlayOneShot(painScreamSound, 0.8f);
    }

    public void Transform()
    {
        isTransformed = true;
        currentState = AIState.Transformed;
        audioSource.PlayOneShot(monsterGrowlSound, 1f);
        animator.SetBool("isTransformed", true);
        // Update visuals here
    }

    public void SetDefeated()
    {
        currentState = AIState.Defeated;
    }
}
