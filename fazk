using UnityEngine;
using UnityEngine.InputSystem;

public class PlayerController : MonoBehaviour
{
    [Header("Movement")]
    [SerializeField] private float walkSpeed = 5f;
    [SerializeField] private float sprintSpeed = 8f;
    [SerializeField] private float crouchSpeed = 2.5f;
    [SerializeField] private float groundDrag = 5f;
    [SerializeField] private float jumpForce = 5f;
    [SerializeField] private float airDrag = 2f;

    [Header("Stamina")]
    [SerializeField] private float maxStamina = 100f;
    [SerializeField] private float staminaDrainRate = 20f;
    [SerializeField] private float staminaRegenRate = 15f;

    [Header("Ground Check")]
    [SerializeField] private float groundDrag_var = 0.25f;
    [SerializeField] private float playerHeight = 2f;
    [SerializeField] private LayerMask groundLayer;

    [Header("Footstep Audio")]
    [SerializeField] private AudioClip[] footstepClips;
    [SerializeField] private float footstepInterval = 0.4f;

    private Rigidbody rb;
    private Transform cam;
    private float currentStamina;
    private float verticalInput;
    private float horizontalInput;
    private bool isGrounded;
    private bool isSprinting;
    private bool isCrouching;
    private float footstepTimer;
    private Vector3 moveDirection;
    private float lastStaminaValue;

    public float CurrentStamina => currentStamina;
    public float MaxStamina => maxStamina;

    private void Start()
    {
        rb = GetComponent<Rigidbody>();
        cam = GetComponentInChildren<Camera>().transform;
        currentStamina = maxStamina;
        rb.drag = groundDrag;
    }

    private void Update()
    {
        HandleInput();
        HandleStamina();
        HandleFootsteps();
        UpdateDrag();
        SpeedControl();
    }

    private void FixedUpdate()
    {
        Movement();
    }

    private void HandleInput()
    {
        verticalInput = Input.GetAxis("Vertical");
        horizontalInput = Input.GetAxis("Horizontal");
        isSprinting = Input.GetKey(KeyCode.LeftShift) && currentStamina > 0 && isGrounded;
        isCrouching = Input.GetKey(KeyCode.LeftControl);

        // Check if grounded
        isGrounded = Physics.Raycast(transform.position, Vector3.down, playerHeight * 0.5f + 0.2f, groundLayer);
    }

    private void Movement()
    {
        moveDirection = transform.forward * verticalInput + transform.right * horizontalInput;

        float currentSpeed = isCrouching ? crouchSpeed : (isSprinting ? sprintSpeed : walkSpeed);
        rb.velocity = new Vector3(moveDirection.x * currentSpeed, rb.velocity.y, moveDirection.z * currentSpeed);
    }

    private void HandleStamina()
    {
        if (isSprinting && verticalInput != 0)
        {
            currentStamina -= staminaDrainRate * Time.deltaTime;
            currentStamina = Mathf.Max(0, currentStamina);
        }
        else if (currentStamina < maxStamina)
        {
            currentStamina += staminaRegenRate * Time.deltaTime;
            currentStamina = Mathf.Min(maxStamina, currentStamina);
        }

        lastStaminaValue = currentStamina;
    }

    private void HandleFootsteps()
    {
        if (isGrounded && (verticalInput != 0 || horizontalInput != 0))
        {
            footstepTimer -= Time.deltaTime;
            if (footstepTimer <= 0)
            {
                float interval = isSprinting ? footstepInterval * 0.6f : footstepInterval;
                AudioSource.PlayClipAtPoint(footstepClips[Random.Range(0, footstepClips.Length)], 
                    transform.position, 0.5f);
                footstepTimer = interval;
            }
        }
        else
        {
            footstepTimer = 0;
        }
    }

    private void UpdateDrag()
    {
        if (isGrounded)
        {
            rb.drag = groundDrag;
        }
        else
        {
            rb.drag = airDrag;
        }
    }

    private void SpeedControl()
    {
        Vector3 flatVel = new Vector3(rb.velocity.x, 0f, rb.velocity.z);

        if (flatVel.magnitude > (isSprinting ? sprintSpeed : walkSpeed))
        {
            Vector3 limitedVel = flatVel.normalized * (isSprinting ? sprintSpeed : walkSpeed);
            rb.velocity = new Vector3(limitedVel.x, rb.velocity.y, limitedVel.z);
        }
    }

    public void Interact(InteractionSystem interaction)
    {
        interaction.PerformInteraction();
    }
}
using UnityEngine;

public class FlashlightSystem : MonoBehaviour
{
    [SerializeField] private Light flashlightLight;
    [SerializeField] private float maxBattery = 100f;
    [SerializeField] private float batteryDrainRate = 10f;
    [SerializeField] private float batteryRechargeRate = 5f;
    [SerializeField] private AudioClip toggleSound;
    [SerializeField] private float batteryWarningThreshold = 20f;

    private float currentBattery;
    private bool isFlashlightOn;
    private AudioSource audioSource;

    public float CurrentBattery => currentBattery;
    public float MaxBattery => maxBattery;
    public bool IsOn => isFlashlightOn;

    private void Start()
    {
        audioSource = GetComponent<AudioSource>();
        currentBattery = maxBattery;
        flashlightLight.enabled = false;
    }

    private void Update()
    {
        if (Input.GetKeyDown(KeyCode.F))
        {
            ToggleFlashlight();
        }

        if (isFlashlightOn)
        {
            currentBattery -= batteryDrainRate * Time.deltaTime;
            if (currentBattery <= 0)
            {
                currentBattery = 0;
                TurnOffFlashlight();
            }
        }
    }

    private void ToggleFlashlight()
    {
        if (currentBattery > 0)
        {
            isFlashlightOn = !isFlashlightOn;
            flashlightLight.enabled = isFlashlightOn;
            audioSource.PlayOneShot(toggleSound);
        }
    }

    private void TurnOffFlashlight()
    {
        isFlashlightOn = false;
        flashlightLight.enabled = false;
    }

    public void RechargeBattery()
    {
        currentBattery += batteryRechargeRate;
        currentBattery = Mathf.Min(currentBattery, maxBattery);
    }

    public bool IsBatteryLow => currentBattery < batteryWarningThreshold;
}
