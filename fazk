public class AudioManager : MonoBehaviour
{
    [Header("Audio Sources")]
    [SerializeField] private AudioSource ambientSource;
    [SerializeField] private AudioSource tensionLayer1;
    [SerializeField] private AudioSource tensionLayer2;
    [SerializeField] private AudioSource tensionLayer3;

    [Header("Ambient Clips")]
    [SerializeField] private AudioClip windLoop;
    [SerializeField] private AudioClip castleAmbience;

    [Header("Tension Music")]
    [SerializeField] private AudioClip[] tensionTracks;

    [Header("Tension Control")]
    [SerializeField] private float maxTension = 3f;

    private float currentTension = 0f;
    private BurnDollSystem burnDollSystem;

    private void Start()
    {
        ambientSource.clip = windLoop;
        ambientSource.loop = true;
        ambientSource.Play();

        burnDollSystem = GetComponent<BurnDollSystem>();
    }

    private void Update()
    {
        UpdateTension();
    }

    private void UpdateTension()
    {
        // Tension increases as dolls are burned
        if (burnDollSystem != null)
        {
            float tensionValue = (float)burnDollSystem.DollsBurned / burnDollSystem.TotalDolls;
            currentTension = Mathf.Lerp(currentTension, tensionValue * maxTension, Time.deltaTime * 0.5f);
        }

        // Control which tension layers are active
        tensionLayer1.volume = Mathf.Clamp01(currentTension - 0f);
        tensionLayer2.volume = Mathf.Clamp01(currentTension - 1f);
        tensionLayer3.volume = Mathf.Clamp01(currentTension - 2f);
    }

    public void PlayAmbienceTransition()
    {
        ambientSource.clip = castleAmbience;
        ambientSource.Play();
    }
}
