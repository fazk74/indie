public class DeathScreen : MonoBehaviour
{
    [SerializeField] private Text deathMessage;
    [SerializeField] private Image bloodEffect;

    private void Start()
    {
        deathMessage.text = "Haaira caught you...\n\nPress any key to restart";
        StartCoroutine(FadeInBlood());
    }

    private System.Collections.IEnumerator FadeInBlood()
    {
        Color color = bloodEffect.color;
        for (float i = 0; i < 1f; i += Time.deltaTime)
        {
            color.a = i;
            bloodEffect.color = color;
            yield return null;
        }
    }
}
