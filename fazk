public class HaairaTransform : MonoBehaviour
{
    [Header("Transformation")]
    [SerializeField] private GameObject normalForm;
    [SerializeField] private GameObject monsterForm;
    [SerializeField] private ParticleSystem transformationEffect;
    [SerializeField] private AudioClip transformationSound;

    [Header("Visual Changes")]
    [SerializeField] private Light haairaLight;
    [SerializeField] private Color normalLightColor = Color.white;
    [SerializeField] private Color monsterLightColor = new Color(0, 0.5f, 1f); // Cyan

    private AudioSource audioSource;
