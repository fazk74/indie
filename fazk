public class InteractionSystem : MonoBehaviour
{
    [SerializeField] private InteractionType interactionType;
    [SerializeField] private GameObject interactableObject;
    [SerializeField] private AudioClip interactionSound;
    [SerializeField] private Canvas interactionPrompt;

    private AudioSource audioSource;
    private PlayerController playerController;

    public enum InteractionType { ReadNote, CollectDoll, BurnDoll, OpenDoor }

    private void Start()
    {
        audioSource = GetComponent<AudioSource>();
        if (interactionPrompt) interactionPrompt.enabled = false;
    }

    private void Update()
    {
        if (Input.GetKeyDown(KeyCode.E) && interactionPrompt.enabled)
        {
            PerformInteraction();
        }
    }

    private void OnTriggerEnter(Collider collision)
    {
        if (collision.CompareTag("Player"))
        {
            if (interactionPrompt) interactionPrompt.enabled = true;
        }
    }

    private void OnTriggerExit(Collider collision)
    {
        if (collision.CompareTag("Player"))
        {
            if (interactionPrompt) interactionPrompt.enabled = false;
        }
    }

    public void PerformInteraction()
    {
        if (interactionSound)
            audioSource.PlayOneShot(interactionSound);

        switch (interactionType)
        {
            case InteractionType.ReadNote:
                ReadNote();
                break;
            case InteractionType.CollectDoll:
                CollectDoll();
                break;
            case InteractionType.BurnDoll:
                BurnDoll();
                break;
            case InteractionType.OpenDoor:
                OpenDoor();
                break;
        }
    }

    private void ReadNote()
    {
        Debug.Log("Reading note: " + interactableObject.name);
        // Show UI with note content
    }

    private void CollectDoll()
    {
        Debug.Log("Doll collected!");
        Destroy(interactableObject);
    }

    private void BurnDoll()
    {
        BurnDollSystem burnSystem = FindObjectOfType<BurnDollSystem>();
        if (burnSystem && burnSystem.CanBurnDoll())
        {
            burnSystem.BurnDoll(interactableObject);
        }
    }

    private void OpenDoor()
    {
        GetComponent<Animator>().SetBool("isOpen", true);
    }
}
