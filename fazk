    private void Start()
    {
        audioSource = GetComponent<AudioSource>();
        normalForm.SetActive(true);
        monsterForm.SetActive(false);
    }

    public void PerformTransformation()
    {
        if (isTransformed) return;

        isTransformed = true;

        // Play transformation animation
        transformationEffect.Play();
        audioSource.PlayOneShot(transformationSound, 1f);

        // Switch models
        normalForm.SetActive(false);
        monsterForm.SetActive(true);

        // Change lighting
        haairaLight.color = monsterLightColor;
        haairaLight.intensity *= 1.5f;

        // Update animator on monster form
        Animator monsterAnimator = monsterForm.GetComponent<Animator>();
        if (monsterAnimator)
        {
            monsterAnimator.SetBool("isTransformed", true);
        }
    }

    public bool IsTransformed => isTransformed;
}
