public class EventsManager : MonoBehaviour
{
    [Header("Doll Spawning")]
    [SerializeField] private GameObject dollPrefab;
    [SerializeField] private Transform[] dollSpawnPoints;
    [SerializeField] private int totalDolls = 7;

    [Header("Paranormal Events")]
    [SerializeField] private float paranormalEventChance = 0.3f;
    [SerializeField] private float eventCheckInterval = 10f;
    [SerializeField] private AudioClip[] paranormalSounds;

    [Header("Random Events")]
    [SerializeField] private Light[] castleLights;

    private List<GameObject> spawnedDolls = new List<GameObject>();
    private float eventTimer;
    private AudioSource audioSource;

    private void Start()
    {
        audioSource = GetComponent<AudioSource>();
        SpawnDolls();
        eventTimer = eventCheckInterval;
    }

    private void Update()
    {
        eventTimer -= Time.deltaTime;
        if (eventTimer <= 0)
        {
            CheckForParanormalEvent();
            eventTimer = eventCheckInterval;
        }
    }

    private void SpawnDolls()
    {
        // Shuffle spawn points for randomization
        List<Transform> shuffledPoints = new List<Transform>(dollSpawnPoints);
        for (int i = 0; i < shuffledPoints.Count; i++)
        {
            Transform temp = shuffledPoints[i];
            int randomIndex = Random.Range(i, shuffledPoints.Count);
            shuffledPoints[i] = shuffledPoints[randomIndex];
            shuffledPoints[randomIndex] = temp;
        }

        for (int i = 0; i < totalDolls && i < shuffledPoints.Count; i++)
        {
            GameObject doll = Instantiate(dollPrefab, shuffledPoints[i].position, Quaternion.identity);
            spawnedDolls.Add(doll);
        }
    }

    private void CheckForParanormalEvent()
    {
        if (Random.value < paranormalEventChance)
        {
            TriggerParanormalEvent();
        }
    }

    private void TriggerParanormalEvent()
    {
        int eventType = Random.Range(0, 3);

        switch (eventType)
        {
            case 0: // Lights flicker
                StartCoroutine(FlickerLights());
                break;
            case 1: // Strange sound
                audioSource.PlayOneShot(paranormalSounds[Random.Range(0, paranormalSounds.Length)], 0.6f);
                break;
            case 2: // Multiple effects
                StartCoroutine(FlickerLights());
                audioSource.PlayOneShot(paranormalSounds[Random.Range(0, paranormalSounds.Length)], 0.6f);
                break;
        }
    }

    private System.Collections.IEnumerator FlickerLights()
    {
        for (int i = 0; i < 5; i++)
        {
            foreach (Light light in castleLights)
            {
                light.enabled = !light.enabled;
            }
            yield return new WaitForSeconds(0.15f);
        }

        foreach (Light light in castleLights)
        {
            light.enabled = true;
        }
    }

    public void RemoveDoll(GameObject doll)
    {
        spawnedDolls.Remove(doll);
    }
}
