public class BurnDollSystem : MonoBehaviour
{
    [Header("Burning Mechanics")]
    [SerializeField] private ParticleSystem fireParticles;
    [SerializeField] private AudioClip fireBurningSound;
    [SerializeField] private AudioClip dollScreamSound;
    [SerializeField] private float burnDuration = 3f;
    [SerializeField] private Light fireLight;

    [Header("Progression")]
    [SerializeField] private int totalDollsToBurn = 7;

    private int dollsBurned = 0;
    private bool isBurning = false;
    private HaairaAI haairaAI;
    private AudioSource audioSource;

    public int DollsBurned => dollsBurned;
    public int TotalDolls => totalDollsToBurn;

    private void Start()
    {
        audioSource = GetComponent<AudioSource>();
        haairaAI = GameObject.Find("Haaira").GetComponent<HaairaAI>();
    }

    public void BurnDoll(GameObject doll)
    {
        if (!isBurning && dollsBurned < totalDollsToBurn)
        {
            StartCoroutine(BurnDollCoroutine(doll));
        }
    }

    private IEnumerator BurnDollCoroutine(GameObject doll)
    {
        isBurning = true;
        fireParticles.Play();
        audioSource.PlayOneShot(fireBurningSound, 0.8f);

        yield return new WaitForSeconds(0.5f);
        audioSource.PlayOneShot(dollScreamSound, 1f);

        // Haaira reacts
        haairaAI.OnDollBurned();

        yield return new WaitForSeconds(burnDuration);

        dollsBurned++;
        fireParticles.Stop();
        Destroy(doll);

        // Check if transformation threshold reached
        if (dollsBurned == 6)
        {
            haairaAI.Transform();
        }

        // Check if game won
        if (dollsBurned >= totalDollsToBurn)
        {
            GameManager.instance.TriggerEndingSequence();
        }

        isBurning = false;
    }

    public bool CanBurnDoll()
    {
        return !isBurning && dollsBurned < totalDollsToBurn;
    }
}
