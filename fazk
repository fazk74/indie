        if (settingsPanel) settingsPanel.enabled = false;
    }

    private void StartGame()
    {
        SceneManager.LoadScene("CinematicIntro");
    }

    private void ShowSettings()
    {
        if (settingsPanel)
            settingsPanel.enabled = !settingsPanel.enabled;
    }

    private void QuitGame()
    {
        Application.Quit();
    }
}
